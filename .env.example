# DevIA – Intranet Devitalia (https://github.com/devitalia/intranet)
# DB read-only: server 28.5.1.253:3306, database intranet_devitalia, utente dbsync
CHATBOT_DB_RO_DSN=mysql://dbsync:PASSWORD@28.5.1.253:3306/intranet_devitalia
# Token lungo per chiamate da DevIA verso Laravel. In Laravel: DEVIA_LARAVEL_TOOL_TOKEN
CHATBOT_TOOL_TOKEN=

# LLM LOCALE (Ollama) – nessuna chiave, tutto in locale
# 1. Installa Ollama: https://ollama.com
# 2. Scarica un modello: ollama run mistral (consigliato) oppure ollama run llama3.2:3b
# 3. DevIA userà http://localhost:11434/v1 (default)
# Se l'LLM rifiuta ("non posso accedere ai dati") pur con contesto corretto, prova mistral o phi3 (vedi docs/CONFIGURATION.md)
DEVIA_LLM_BASE_URL=http://localhost:11434/v1
DEVIA_LLM_MODEL=mistral
# Lascia vuoto per Ollama; solo per cloud (OpenAI/Azure) imposta DEVIA_LLM_API_KEY
# DEVIA_LLM_API_KEY=

# Repo intranet (opzionale). Default: nessun codice in prompt (contesto = schema DB + istruzioni; risposte cercate con query).
# DEVIA_REPO_PATH=/repo
# Se > 0, carica app/Models/*.php fino a N caratteri (es. 20000). Default 0.
# DEVIA_REPO_MAX_CHARS=0

# TTS Piper: modelli italiani (voce naturale). Percorso al file .onnx (es. Paola femminile, Riccardo maschile).
# DEVIA_TTS_ENABLED=1
# Esempio: /models/it_IT-paola-medium.onnx (in Docker monta piper-models come /models)
# DEVIA_TTS_MODEL_PATH=/models/it_IT-paola-medium.onnx
# Opzionale: velocità (0.85 = un po' più veloce)
# DEVIA_TTS_LENGTH_SCALE=0.85

# Debug: log dettagliati in DevIA (chat, query SQL). Per Docker: environment DEVIA_DEBUG=1
# DEVIA_DEBUG=1
